{
  "name": "montessori-allgaeu",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --force",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build --force",
    "content:refresh": "ASTRO_TELEMETRY_DISABLED=1 astro sync --force",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:ci": "npm run format:check && npm run lint && npm run check && npm run test && npm run build",
    "test:e2e": "playwright test",
    "test:all": "npm run format:check && npm run lint && npm run check && npm run test && npm run build && npm run test:e2e",
    "screenshot:mobile": "playwright screenshot --browser chromium --viewport-size \"390,844\""
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/manrope": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "@lucide/astro": "1.24.0",
    "astro": "7.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "1.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
