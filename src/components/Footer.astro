---
import { Mail, MapPin, Phone } from "@lucide/astro";
import Brand from "./Brand.astro";
import { footerNavigation, site } from "@/data/site";
---

<footer class="site-footer">
  <div class="container site-footer__top">
    <div class="site-footer__identity">
      <Brand inverted />
      <address>
        <span
          ><MapPin size={16} aria-hidden="true" />{site.address.street}<br />{
            site.address.city
          }</span
        >
        <a href={`tel:${site.phone}`}><Phone size={16} aria-hidden="true" />{site.phoneDisplay}</a>
        <a href={`mailto:${site.email}`}><Mail size={16} aria-hidden="true" />{site.email}</a>
      </address>
    </div>
    <nav class="site-footer__nav" aria-label="Footer-Navigation">
      {
        footerNavigation.map((group) => (
          <div>
            <h2>{group.title}</h2>
            <ul>
              {group.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>
  <div class="container site-footer__bottom">
    <div class="site-footer__legal">
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
      <a href="/downloads/">Downloads</a>
    </div>
    <p>© {new Date().getFullYear()} Montessori Allgäu · Kindergarten & Schule</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: clamp(3.5rem, 5vw, 4.5rem) 0 1.5rem;
    color: var(--white);
    background: var(--forest);
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 2fr);
    gap: clamp(3rem, 8vw, 8rem);
    padding-bottom: 2.75rem;
  }

  .site-footer__identity address {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 2rem;
    color: rgb(255 253 250 / 0.7);
    font-size: 0.82rem;
    font-style: normal;
    line-height: 1.6;
  }

  .site-footer__identity address span,
  .site-footer__identity address a {
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    gap: 0.5rem;
    color: inherit;
    text-decoration: none;
  }

  .site-footer__identity address svg {
    margin-top: 0.25rem;
    color: var(--ochre);
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
  }

  .site-footer__nav h2 {
    margin-bottom: 1rem;
    color: var(--white);
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .site-footer__nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__nav li {
    margin-bottom: 0.55rem;
  }

  .site-footer__nav a {
    color: rgb(255 253 250 / 0.68);
    font-size: 0.78rem;
    text-decoration: none;
  }

  .site-footer__nav a:hover {
    color: var(--white);
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgb(255 253 250 / 0.2);
  }

  .site-footer__bottom p,
  .site-footer__bottom a {
    margin: 0;
    color: rgb(255 253 250 / 0.55);
    font-size: 0.7rem;
    text-decoration: none;
  }

  .site-footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.3rem;
  }

  @media (max-width: 980px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }

    .site-footer__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .site-footer__nav {
      grid-template-columns: 1fr;
    }

    .site-footer__bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
