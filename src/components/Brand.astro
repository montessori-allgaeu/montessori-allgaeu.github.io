---
import { Image } from "astro:assets";
import officialLogo from "@/assets/brand/official/logo-montessori-allgaeu-ab-2022.png";

interface Props {
  inverted?: boolean;
  compact?: boolean;
}

const { inverted = false, compact = false } = Astro.props;
---

<a
  class:list={["brand", { "brand--inverted": inverted, "brand--compact": compact }]}
  href="/"
  aria-label="Montessori Allgäu – Schule & Kindergarten – Startseite"
>
  <Image class="brand__logo" src={officialLogo} alt="" width={638} height={135} loading="eager" />
</a>

<style>
  .brand {
    display: inline-block;
    width: min(15.5rem, 100%);
    min-width: 0;
    line-height: 0;
    text-decoration: none;
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand__logo {
    width: 100%;
    height: auto;
  }

  .brand--compact {
    width: min(12rem, 100%);
  }

  .brand--inverted {
    width: min(16.5rem, 100%);
  }
</style>
