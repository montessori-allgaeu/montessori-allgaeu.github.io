---
import { ChevronDown, Menu, X } from "@lucide/astro";
import Brand from "./Brand.astro";
import { mainNavigation, supportLink } from "@/data/site";

const path = Astro.url.pathname;
const active = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<header class="site-header">
  <div class="site-header__inner">
    <Brand />
    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {
        mainNavigation.map((item) => (
          <div class="desktop-nav__item">
            <a
              class:list={["desktop-nav__link", { active: active(item.href) }]}
              href={item.href}
              aria-current={path === item.href ? "page" : undefined}
            >
              {item.label}
            </a>
            {item.children.length > 0 && (
              <div class="desktop-nav__submenu">
                {item.children.map((child) => (
                  <a
                    class:list={{ active: path === child.href }}
                    href={child.href}
                    aria-current={path === child.href ? "page" : undefined}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </nav>
    <a class="button header-cta" href="/kennenlernen/">Monte kennenlernen</a>
    <details class="mobile-menu">
      <summary aria-label="Navigation öffnen" aria-expanded="false">
        <Menu class="mobile-menu__open" size={24} aria-hidden="true" />
        <X class="mobile-menu__close" size={24} aria-hidden="true" />
      </summary>
      <nav aria-label="Mobile Navigation">
        {
          mainNavigation.map((item, index) => {
            const children = item.children.filter((child) => child.href !== supportLink.href);

            if (children.length === 0) {
              return (
                <a
                  class:list={["mobile-menu__direct", { active: active(item.href) }]}
                  href={item.href}
                  aria-current={path === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              );
            }

            const groupId = `mobile-menu-group-${index}`;
            const groupActive = active(item.href) || children.some((child) => active(child.href));

            return (
              <details
                class="mobile-menu__group"
                data-mobile-nav-group={item.href}
                open={groupActive}
              >
                <summary aria-controls={groupId} aria-expanded={groupActive ? "true" : "false"}>
                  <span>{item.label}</span>
                  <ChevronDown size={21} aria-hidden="true" />
                </summary>
                <div class="mobile-menu__children" id={groupId}>
                  <a
                    class="mobile-menu__overview"
                    href={item.href}
                    aria-current={path === item.href ? "page" : undefined}
                  >
                    Überblick
                  </a>
                  {children.map((child) => (
                    <a href={child.href} aria-current={path === child.href ? "page" : undefined}>
                      {child.label}
                    </a>
                  ))}
                </div>
              </details>
            );
          })
        }
        <a
          class:list={["mobile-menu__support", { active: active(supportLink.href) }]}
          href={supportLink.href}
          aria-current={path === supportLink.href ? "page" : undefined}
        >
          {supportLink.label}
        </a>
        <div class="mobile-menu__quicklinks">
          <p>Schnellzugriff</p>
          <div>
            <a href="/termine/" aria-current={path === "/termine/" ? "page" : undefined}>Termine</a>
            <a href="/downloads/" aria-current={path === "/downloads/" ? "page" : undefined}
              >Downloads</a
            >
            <a href="/kontakt/" aria-current={path === "/kontakt/" ? "page" : undefined}>Kontakt</a>
          </div>
        </div>
        <a class="button" href="/kennenlernen/">Monte kennenlernen</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 100;
    top: 0;
    height: var(--header-height);
    border-bottom: 1px solid color-mix(in srgb, var(--color-line) 80%, transparent);
    background: color-mix(in srgb, var(--color-canvas) 94%, transparent);
    backdrop-filter: blur(16px);
  }

  .site-header__inner {
    display: grid;
    width: min(calc(100% - 3rem), 1440px);
    height: 100%;
    margin-inline: auto;
    grid-template-columns: auto 1fr auto;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  .desktop-nav {
    display: flex;
    justify-content: flex-end;
    gap: clamp(1.1rem, 2.2vw, 2.4rem);
  }

  .desktop-nav__item {
    position: relative;
  }

  .desktop-nav__link,
  .desktop-nav__submenu a {
    position: relative;
    color: var(--color-text);
    font-size: 0.76rem;
    font-weight: 650;
    text-decoration: none;
  }

  .desktop-nav__link {
    display: block;
    padding: 0.5rem 0;
    font-weight: 500;
    white-space: nowrap;
  }

  .desktop-nav__link::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: var(--color-action);
    content: "";
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 160ms ease;
  }

  .desktop-nav__link:hover::after,
  .desktop-nav__link.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .desktop-nav__submenu {
    position: absolute;
    top: calc(100% + 0.65rem);
    left: -1rem;
    min-width: 15rem;
    padding: 0.45rem;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    box-shadow: 0 1rem 2.5rem rgb(29 43 30 / 0.12);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      visibility 140ms ease;
    visibility: hidden;
  }

  .desktop-nav__submenu::before {
    position: absolute;
    right: 0;
    bottom: 100%;
    left: 0;
    height: 0.75rem;
    content: "";
  }

  .desktop-nav__item:last-child .desktop-nav__submenu {
    right: 0;
    left: auto;
  }

  .desktop-nav__item:hover .desktop-nav__submenu,
  .desktop-nav__item:focus-within .desktop-nav__submenu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
    visibility: visible;
  }

  .desktop-nav__submenu a {
    display: block;
    padding: 0.75rem 0.8rem;
    line-height: 1.35;
  }

  .desktop-nav__submenu a:hover,
  .desktop-nav__submenu a:focus-visible,
  .desktop-nav__submenu a.active {
    background: color-mix(in srgb, var(--color-action) 9%, transparent);
    color: var(--color-action-hover);
  }

  .header-cta {
    min-height: 44px;
    padding-inline: 1.15rem;
    font-size: 0.78rem;
  }

  .mobile-menu {
    display: none;
    width: 46px;
    max-width: 46px;
    min-width: 46px;
  }

  .mobile-menu > summary {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border: 1px solid var(--color-line-strong);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu__close,
  .mobile-menu[open] .mobile-menu__open {
    display: none;
  }

  .mobile-menu[open] .mobile-menu__close {
    display: block;
  }

  .mobile-menu nav {
    position: fixed;
    top: var(--header-height);
    right: 0;
    left: 0;
    display: flex;
    height: calc(100dvh - var(--header-height));
    flex-direction: column;
    gap: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.7rem 1.5rem 2.5rem;
    background: var(--color-canvas);
  }

  .mobile-menu__direct,
  .mobile-menu__group > summary {
    display: flex;
    min-height: 4.65rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text);
    font-family: var(--display);
    font-size: clamp(1.5rem, 6vw, 1.75rem);
    text-decoration: none;
  }

  .mobile-menu__group > summary {
    width: 100%;
    height: auto;
    border-width: 0 0 1px;
    cursor: pointer;
    list-style: none;
    place-items: initial;
  }

  .mobile-menu__group > summary svg {
    flex: 0 0 auto;
    color: var(--color-link);
    transition: transform 160ms ease;
  }

  .mobile-menu__group[open] > summary {
    border-bottom-color: transparent;
    color: var(--color-link);
  }

  .mobile-menu__group[open] > summary svg {
    transform: rotate(180deg);
  }

  .mobile-menu__children {
    display: grid;
    gap: 0;
    padding: 0 0 0.75rem 1rem;
    border-bottom: 1px solid var(--color-line);
  }

  .mobile-menu__children a {
    display: flex;
    min-height: 3rem;
    align-items: center;
    color: var(--color-text);
    font-size: 0.92rem;
    font-weight: 550;
    text-decoration: none;
  }

  .mobile-menu__children a:hover,
  .mobile-menu__children a:focus-visible,
  .mobile-menu__children a[aria-current="page"] {
    color: var(--color-link);
  }

  .mobile-menu__children .mobile-menu__overview {
    font-weight: 750;
  }

  .mobile-menu__direct.active {
    color: var(--color-link);
  }

  .mobile-menu__support {
    display: flex;
    min-height: 3.8rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-link);
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .mobile-menu__quicklinks {
    padding-top: 1.35rem;
  }

  .mobile-menu__quicklinks p {
    margin: 0 0 0.65rem;
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mobile-menu__quicklinks div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.2rem;
  }

  .mobile-menu__quicklinks a {
    min-height: 2.75rem;
    color: var(--color-text);
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 2.75rem;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-action) 55%, transparent);
    text-underline-offset: 0.28em;
  }

  .mobile-menu__quicklinks a[aria-current="page"] {
    color: var(--color-link);
  }

  .mobile-menu nav .button {
    margin-top: 1.4rem;
  }

  :global(body.mobile-menu-open) {
    overflow: hidden;
  }

  @media (max-width: 1180px) {
    .desktop-nav {
      display: none;
    }

    .site-header__inner {
      grid-template-columns: 1fr auto auto;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .site-header__inner {
      width: calc(100% - 2rem);
      grid-template-columns: 1fr auto;
      gap: 0.8rem;
    }

    .header-cta {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu__group > summary svg {
      transition: none;
    }
  }
</style>

<script>
  const mobileMenu = document.querySelector<HTMLDetailsElement>(".mobile-menu");

  if (mobileMenu) {
    const menuButton = mobileMenu.querySelector<HTMLElement>(":scope > summary");
    const groups = Array.from(
      mobileMenu.querySelectorAll<HTMLDetailsElement>(".mobile-menu__group"),
    );
    const backgroundElements = [
      document.querySelector("main"),
      document.querySelector(".site-footer"),
      document.querySelector(".site-header .brand"),
      document.querySelector(".header-cta"),
    ].filter((element): element is HTMLElement => element instanceof HTMLElement);
    const mobileBreakpoint = window.matchMedia("(max-width: 1180px)");

    const updateMenuState = () => {
      const isOpen = mobileMenu.open;
      menuButton?.setAttribute("aria-expanded", String(isOpen));
      menuButton?.setAttribute("aria-label", isOpen ? "Navigation schließen" : "Navigation öffnen");
      document.body.classList.toggle("mobile-menu-open", isOpen);
      backgroundElements.forEach((element) => element.toggleAttribute("inert", isOpen));
    };

    const closeMenuAboveMobileBreakpoint = () => {
      if (!mobileBreakpoint.matches && mobileMenu.open) {
        mobileMenu.open = false;
        updateMenuState();
      }
    };

    groups.forEach((group) => {
      const summary = group.querySelector(":scope > summary");
      const updateGroupState = () => {
        summary?.setAttribute("aria-expanded", String(group.open));

        if (group.open) {
          groups.forEach((otherGroup) => {
            if (otherGroup !== group) otherGroup.open = false;
          });
        }
      };

      group.addEventListener("toggle", updateGroupState);
      updateGroupState();
    });

    mobileMenu.addEventListener("toggle", updateMenuState);
    mobileBreakpoint.addEventListener("change", closeMenuAboveMobileBreakpoint);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && mobileMenu.open) {
        mobileMenu.open = false;
        menuButton?.focus();
      }
    });
    updateMenuState();
  }
</script>
