---
import type { ImageMetadata } from "astro";
import CoverImage from "@/components/CoverImage.astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  reverse?: boolean;
  light?: boolean;
  compact?: boolean;
  portrait?: boolean;
  position?: string;
  mobilePosition?: string;
  widths?: number[];
}

const {
  image,
  alt,
  reverse = false,
  light = false,
  compact = false,
  portrait = false,
  position = "center",
  mobilePosition = position,
  widths = [640, 960, 1280],
} = Astro.props;
---

<section
  class:list={[
    "split",
    {
      "split--reverse": reverse,
      "split--light": light,
      "split--compact": compact,
      "split--portrait": portrait,
    },
  ]}
>
  <div class="split__content">
    <div class="split__content-inner"><slot /></div>
  </div>
  <div class="split__media">
    <CoverImage
      {image}
      {alt}
      {widths}
      sizes="(max-width: 840px) 100vw, 50vw"
      {position}
      {mobilePosition}
    />
  </div>
</section>
