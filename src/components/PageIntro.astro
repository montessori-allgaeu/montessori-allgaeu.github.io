---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="page-intro">
  <div class="container page-intro__grid">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
    </div>
    <div class="page-intro__aside">
      <p class="lead">{intro}</p>
      <slot />
    </div>
  </div>
</section>
