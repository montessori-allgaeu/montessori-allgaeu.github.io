---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  position?: string;
  mobilePosition?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  image,
  alt,
  widths = [640, 960, 1280],
  sizes = "100vw",
  position = "center",
  mobilePosition = position,
  loading = "lazy",
  fetchpriority,
} = Astro.props;
---

<Image
  class="cover-image"
  src={image}
  {alt}
  {widths}
  {sizes}
  {loading}
  {fetchpriority}
  style={`--cover-position: ${position}; --cover-position-mobile: ${mobilePosition};`}
/>
