---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import CTASection from "@/components/CTASection.astro";
import TextLink from "@/components/TextLink.astro";
---

<BaseLayout
  title="Träger & Verein"
  description="Der gemeinnützige Monte e.V. trägt Montessori-Kindergarten und Schule Allgäu. Eltern sind Mitglieder, wählen den Vorstand und gestalten die Organisation mit."
>
  <PageIntro
    eyebrow="Träger & Verein"
    title="Die Schule und der Kindergarten sind wir."
    intro="Nicht der Staat, kein Konzern und kein einzelner Eigentümer trägt die Monte. Träger ist ein gemeinnütziger Verein, dessen Mitglieder Verantwortung gemeinsam übernehmen."
  />

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Monte e.V.</p>
        <h2>Eltern tragen die Organisation demokratisch.</h2>
      </div>
      <div>
        <p class="lead">
          Alle Elternfamilien werden Mitglied im Verein. Die Mitgliederversammlung wählt den
          Vorstand, entscheidet über grundlegende Fragen und schafft damit eine Nähe, die in einem
          großen staatlichen System kaum möglich ist.
        </p>
        <p>
          Der vollständige Name lautet „Monte-Verein zur Förderung der Montessori-Pädagogik im
          Grenzgebiet Oberallgäu/Westallgäu und Bregenzerwald (Österreich) e.V.“ Auch Menschen ohne
          Kind in der Monte können Mitglied werden und unsere Arbeit unterstützen.
        </p>
        <TextLink
          href="/downloads/beitrittserklaerung-verein.pdf"
          label="Beitrittserklärung herunterladen"
        />
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Fünf Säulen</p>
        <h2>Verantwortung ist verteilt – nicht diffus.</h2>
      </div>
      <div class="editorial-cards">
        <article class="editorial-card">
          <p class="eyebrow">01</p><h3>Verein & Vorstand</h3><p>
            Trägt rechtliche, strategische und wirtschaftliche Gesamtverantwortung.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">02</p><h3>Eltern & Elternbeirat</h3><p>
            Bringen Perspektiven, Mitarbeit und gemeinschaftliche Verantwortung ein.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">03</p><h3>Schüler:innen</h3><p>
            Gestalten über Klassenrat, Versammlung und Sprecher:innen ihr Lernumfeld mit.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">04</p><h3>Pädagogisches Team</h3><p>
            Verantwortet Pädagogik, Beobachtung, Begleitung und vorbereitete Umgebung.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">05</p><h3>Verwaltung</h3><p>
            Sichert gemeinsam mit der Geschäftsführung verlässliche Abläufe und Ressourcen.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Vorstand</p>
        <h2>Von den Mitgliedern gewählt.</h2>
      </div>
      <div>
        <ul class="editorial-list">
          <li><strong>Max Sutter</strong> · Vorsitzender</li>
          <li><strong>Claudia Alton</strong> · stellvertretende Vorsitzende</li>
          <li><strong>Markus Lempke</strong> · Schriftführer</li>
          <li><strong>Daniel Hunold</strong> · Finanzvorstand</li>
        </ul>
        <p>
          Den Vorstand erreicht ihr unter <a href="mailto:vorstand@montessori-allgaeu.de"
            >vorstand@montessori-allgaeu.de</a
          >.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--terracotta">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Mitgliedsbeitrag</p><h2>
          Klein im Betrag. Grundlegend in der Bedeutung.
        </h2>
      </div>
      <div>
        <ul class="editorial-list membership-list">
          <li>Familien: 50 € jährlich</li>
          <li>Einzelpersonen: 40 € jährlich</li>
          <li>Alleinerziehende: 30 € jährlich</li>
        </ul>
      </div>
    </div>
  </section>

  <CTASection
    title="Du möchtest die Monte unterstützen?"
    text="Werde Mitglied, bring dich als Elternteil ein oder unterstütze unsere gemeinnützige Arbeit mit einer Spende."
    primaryHref="/downloads/beitrittserklaerung-verein.pdf"
    primaryLabel="Mitglied werden"
    secondaryHref="/spenden/"
    secondaryLabel="Spenden"
  />
</BaseLayout>

<style>
  .membership-list li {
    border-color: rgb(255 253 250 / 0.28);
    color: var(--white);
  }

  .membership-list li::before {
    background: var(--white);
  }
</style>
