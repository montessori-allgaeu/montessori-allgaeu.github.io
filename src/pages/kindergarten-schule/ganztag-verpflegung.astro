---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import ImageSplit from "@/components/ImageSplit.astro";
import CTASection from "@/components/CTASection.astro";
import TextLink from "@/components/TextLink.astro";
import AfternoonProgram from "@/components/AfternoonProgram.astro";
import { getAfternoonProgram, getWebsiteSettings } from "@/data/content";
import natureStudyImage from "@/assets/images/editorial/ganztag-nature-study.webp";
import lunchImage from "@/assets/images/editorial/ganztag-lunch.webp";

const [{ meals }, afternoonProgram] = await Promise.all([
  getWebsiteSettings(),
  getAfternoonProgram(),
]);
---

<BaseLayout
  title="Ganztag & Verpflegung"
  description="Offene Ganztagsschule und frisches Mittagessen an der Montessori-Schule Allgäu: ein verlässlicher Rahmen mit Zeit für Beziehung, Bewegung und Projekte."
>
  <PageIntro
    eyebrow="Ganztagsschule & Verpflegung"
    title="Ein ganzer Tag darf sich auch ganz anfühlen."
    intro="Nach dem Lernen am Vormittag braucht es Essen, Bewegung, Ruhe, Beziehung und Raum für eigene Vorhaben. Unsere Ganztagsschule ist deshalb mehr als Betreuung."
  />

  <ImageSplit
    image={natureStudyImage}
    alt="Kinder untersuchen gemeinsam einen Bach"
    position="center 46%"
  >
    <p class="eyebrow">Offene Ganztagsschule</p>
    <h2>Verlässlicher Rahmen. Freier Nachmittag.</h2>
    <p>
      Für das freiwillige Nachmittagsangebot könnt ihr <strong
        >{
          `${afternoonProgram.minimumAfternoons}–${afternoonProgram.maximumAfternoons} Nachmittage`
        }</strong
      > von Montag bis Freitag wählen.
    </p>
    <p>{afternoonProgram.intro}</p>
    <p>{afternoonProgram.secundariaNote}</p>
    <TextLink
      href="#nachmittagsangebote"
      label={`Angebote ${afternoonProgram.activeSchoolYear} ansehen`}
    />
  </ImageSplit>

  <AfternoonProgram program={afternoonProgram} />

  <ImageSplit
    image={lunchImage}
    alt="Kinder und Erwachsene essen gemeinsam zu Mittag"
    reverse
    light
    position="center 48%"
  >
    <p class="eyebrow">Mittagessen</p>
    <h2>Frisch, gemeinsam und mit Liebe gekocht.</h2>
    <p>
      „{meals.provider}“ liefert ein frisch zubereitetes Mittagessen. Wo möglich, werden regionale
      und saisonale Zutaten verwendet.
    </p>
  </ImageSplit>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Gemeinschaft</p>
        <h2>Auch Essen ist ein Lernort.</h2>
      </div>
      <div>
        <p class="lead">
          Tisch decken, warten, teilen, probieren, Grenzen spüren, aufräumen: Ein gemeinsames Essen
          ist voller kleiner Momente von Selbstständigkeit und Verbindung.
        </p>
        <p>
          Der regelmäßige Pausenverkauf wird von Schüler:innen mit Unterstützung aus der
          Elternschaft organisiert. Der Erlös kommt den Klassen für gemeinsame Projekte zugute.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Fragen zu Ganztag, Auswahl oder Essen?"
    text="Das Schulbüro hilft euch bei Buchungszeiten, Verfügbarkeit, Nachmittagsangeboten und dem aktuellen organisatorischen Rahmen weiter."
    primaryHref="/kontakt/"
    primaryLabel="Schulbüro kontaktieren"
    secondaryHref="/kennenlernen/kosten/"
    secondaryLabel="Kosten ansehen"
  />
</BaseLayout>
