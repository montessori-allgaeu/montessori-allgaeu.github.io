---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import ImageSplit from "@/components/ImageSplit.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import CTASection from "@/components/CTASection.astro";
import schoolImage from "@/assets/images/editorial/school.webp";
import classImage from "@/assets/images/editorial/class.webp";
import roomImage from "@/assets/images/editorial/room.webp";
---

<BaseLayout
  title="Montessori-Schule"
  description="Unsere Montessori-Schule in Oberstaufen begleitet Kinder und Jugendliche jahrgangsgemischt von Klasse 1 bis 10 – selbstbestimmt, anspruchsvoll und in klaren Grenzen."
>
  <PageIntro
    eyebrow="Montessori-Schule · Klasse 1–10"
    title="Den eigenen Weg finden – und ihn wirklich gehen."
    intro="Kinder und Jugendliche arbeiten in jahrgangsgemischten Lerngruppen, übernehmen Verantwortung und entwickeln fachliche Kompetenz in ihrem Tempo. Unsere Aufgabe ist, genau hinzusehen und den nächsten möglichen Schritt vorzubereiten."
  />

  <ImageSplit
    image={schoolImage}
    alt="Schülerinnen arbeiten gemeinsam an einem Tisch"
    position="center 42%"
  >
    <p class="eyebrow">Freiarbeit und Fachlichkeit</p>
    <h2>Selbstbestimmt heißt nicht unbegleitet.</h2>
    <p>
      In der Freiarbeit wählen Kinder innerhalb eines vorbereiteten Rahmens ihre Tätigkeit, Partner
      und Dauer. Darin erleben sie Konzentration, Wiederholung und echte Selbstständigkeit.
      Gebundene Lernzeiten, Fachunterricht, Projekte und gemeinsame Kreise geben zusätzliche
      Struktur.
    </p>
    <p>
      Pädagog:innen machen Lernstände sichtbar, geben Einführungen und vereinbaren nächste Schritte.
      Wer schnell und anspruchsvoll arbeiten möchte, wird gefördert. Wer mehr Zeit braucht, bekommt
      sie.
    </p>
  </ImageSplit>

  <section class="section section--light">
    <div class="container">
      <SectionHeading
        eyebrow="Drei Lernstufen"
        title="Gemeinsam wachsen. Mit jedem Alter anders."
      />
      <div class="editorial-cards">
        <article class="editorial-card">
          <p class="eyebrow">Klasse 1–4</p>
          <h3>Primaria</h3>
          <p>
            Die Freude am Entdecken, konkrete Materialien und der Aufbau selbstständiger
            Arbeitsweisen stehen im Mittelpunkt.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">Klasse 5–7</p>
          <h3>Sekundaria</h3>
          <p>
            Interessen vertiefen sich, abstraktes Denken wächst und Lernen öffnet sich stärker zu
            Projekten, Welt und Gemeinschaft.
          </p>
        </article>
        <article class="editorial-card">
          <p class="eyebrow">Klasse 8–10</p>
          <h3>Tertia</h3>
          <p>
            Jugendliche klären ihre Ziele, übernehmen Verantwortung und bereiten sich individuell
            auf Abschluss und nächsten Lebensweg vor.
          </p>
        </article>
      </div>
    </div>
  </section>

  <ImageSplit
    image={classImage}
    alt="Kinder arbeiten in einer jahrgangsgemischten Lerngruppe"
    reverse
    position="center 40%"
  >
    <p class="eyebrow">Abschlüsse</p>
    <h2>Ein Abschluss ist ein Wegweiser – nicht der Wert eines Kindes.</h2>
    <p>
      Wir bereiten auf anerkannte Abschlüsse vor, ohne die gesamte Schulzeit dem Prüfungsformat
      unterzuordnen. Gemeinsam mit dem jungen Menschen und der Familie klären wir Ziel, Lernstand
      und nächste Schritte.
    </p>
    <ul class="editorial-list">
      <li>Erfolgreicher Mittelschulabschluss / Montessori-Abschluss</li>
      <li>Qualifizierender Abschluss der Mittelschule („Quali“)</li>
      <li>Mittlerer Schulabschluss über eine kooperierende staatliche Schule (M10)</li>
    </ul>
    <p class="small muted">
      Prüfungswege und Kooperationen können sich ändern. Verbindliche Details klären wir im
      Aufnahme- und Beratungsgespräch.
    </p>
  </ImageSplit>

  <section class="section section--light">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Alltag</p>
        <h2>Rhythmus gibt Sicherheit.</h2>
        <p class="lead">
          Morgenkreise, Freiarbeit, Fachunterricht, Bewegung, Projekte und gemeinsame Verantwortung
          bilden einen verlässlichen Wochenrahmen.
        </p>
        <p>
          Klassenrat und Schülerversammlung geben jungen Menschen eine echte Stimme. Konflikte
          werden nicht vermieden oder über Schuld gelöst, sondern angesprochen, geklärt und als
          Lernraum genutzt.
        </p>
      </div>
      <div class="image-frame image-frame--landscape">
        <img
          src={roomImage.src}
          alt="Vorbereiteter Klassenraum der Montessori-Schule"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <CTASection
    title="Einschulung beginnt mit einem ehrlichen Kennenlernen."
    text="Ihr sollt wissen, was ihr von uns erwarten könnt – und was nicht. Wir möchten nicht möglichst viele, sondern passende Familien aufnehmen."
    primaryHref="/kennenlernen/aufnahme-schule/"
    primaryLabel="Aufnahme Schule"
    secondaryHref="/kennenlernen/haeufige-fragen/"
    secondaryLabel="Häufige Fragen"
  />
</BaseLayout>
