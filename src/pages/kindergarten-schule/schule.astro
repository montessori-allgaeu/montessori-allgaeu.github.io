---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import ImageSplit from "@/components/ImageSplit.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import CTASection from "@/components/CTASection.astro";
import TextLink from "@/components/TextLink.astro";
import VimeoEmbed from "@/components/VimeoEmbed.astro";
import { getWebsiteSettings } from "@/data/content";
import thousandChainImage from "@/assets/images/editorial/school-thousand-chain.webp";
import classImage from "@/assets/images/editorial/class.webp";
import roomImage from "@/assets/images/editorial/room.webp";
import erdkinderplanPoster from "@/assets/images/editorial/erdkinderplan-bauwagen.jpg";

const { openingHours } = await getWebsiteSettings();
---

<BaseLayout
  title="Montessori-Schule"
  description="Unsere Montessori-Schule in Oberstaufen begleitet Kinder und Jugendliche jahrgangsgemischt von Klasse 1 bis 10 – selbstbestimmt, anspruchsvoll und in klaren Grenzen."
>
  <PageIntro
    eyebrow="Montessori-Schule · Klasse 1–10"
    title="Den eigenen Weg finden – und ihn wirklich gehen."
    intro="Kinder und Jugendliche arbeiten in jahrgangsgemischten Lerngruppen, übernehmen Verantwortung und entwickeln fachliche Kompetenz in ihrem Tempo. Unsere Aufgabe ist, genau hinzusehen und den nächsten möglichen Schritt vorzubereiten."
  />

  <ImageSplit
    image={thousandChainImage}
    alt="Zwei Schüler arbeiten gemeinsam mit der Tausenderkette"
    position="center 48%"
  >
    <p class="eyebrow">Freiarbeit und Fachlichkeit</p>
    <h2>Selbstbestimmt heißt nicht unbegleitet.</h2>
    <p>
      In der Freiarbeit wählen Kinder innerhalb eines vorbereiteten Rahmens ihre Tätigkeit, Partner
      und Dauer. Darin erleben sie Konzentration, Wiederholung und echte Selbstständigkeit.
      Gebundene Lernzeiten, Fachunterricht, Projekte und gemeinsame Kreise geben zusätzliche
      Struktur.
    </p>
    <p>
      Pädagog:innen machen Lernstände sichtbar, geben Einführungen und vereinbaren nächste Schritte.
      Wer schnell und anspruchsvoll arbeiten möchte, wird gefördert. Wer mehr Zeit braucht, bekommt
      sie.
    </p>
  </ImageSplit>

  <section class="section section--light">
    <div class="container">
      <SectionHeading
        eyebrow="Drei Lernstufen"
        title="Gemeinsam wachsen. Mit jedem Alter anders."
      />
      <div class="editorial-cards">
        <article class="editorial-card stage-card">
          <p class="eyebrow">Klasse 1–4</p>
          <h3>Primaria</h3>
          <blockquote>„Hilf mir, es selbst zu tun.“</blockquote>
          <p>
            Die Freude am Entdecken, konkrete Materialien und der Aufbau selbstständiger
            Arbeitsweisen stehen im Mittelpunkt.
          </p>
        </article>
        <article class="editorial-card stage-card">
          <p class="eyebrow">Klasse 5–7</p>
          <h3>Sekundaria</h3>
          <blockquote>„Hilf mir, selbst zu denken.“</blockquote>
          <p>
            Interessen vertiefen sich, abstraktes Denken wächst und Lernen öffnet sich stärker zu
            Projekten, Welt und Gemeinschaft.
          </p>
        </article>
        <article class="editorial-card stage-card">
          <p class="eyebrow">Klasse 8–10</p>
          <h3>Tertia</h3>
          <blockquote>„Hilf mir, meinen Platz in der Welt zu finden.“</blockquote>
          <p>
            Jugendliche klären ihre Ziele, übernehmen Verantwortung und bereiten sich individuell
            auf Abschluss und nächsten Lebensweg vor.
          </p>
        </article>
      </div>
      <p class="stage-note small muted">
        Diese drei Leitsätze sind heutige Interpretationen der Montessori-Pädagogik. Sie sind nicht
        als wörtliche Aussagen Maria Montessoris überliefert.
      </p>
    </div>
  </section>

  <section class="section erdkinderplan" aria-labelledby="erdkinderplan-title">
    <div class="container">
      <div class="grid-2 erdkinderplan__intro">
        <div>
          <p class="eyebrow">Erdkinderplan · Sekundaria &amp; Tertia</p>
          <h2 id="erdkinderplan-title">Mit Kopf, Hand und Verantwortung.</h2>
        </div>
        <div>
          <p class="lead">
            Jugendliche lernen besonders tief, wenn Wissen mit echten Aufgaben verbunden ist.
          </p>
          <p>
            Maria Montessori beschrieb dafür den Erdkinderplan: ein Lernen, das theoretische
            Kenntnisse mit praktischer Arbeit, sozialer Verantwortung und gemeinsamer Gestaltung
            verbindet.
          </p>
          <p>
            Wir greifen diesen Gedanken in konkreten Projekten auf. Die Sekundaria B plante und
            baute im Schuljahr 2023/24 über ein Jahr einen Bauwagen. Berechnungen, die
            Auseinandersetzung mit Materialien und die Arbeit mit Werkzeugen führten zu einem
            Ergebnis, das nur gemeinsam entstehen konnte.
          </p>
        </div>
      </div>

      <VimeoEmbed
        videoId="988288187"
        title="Montessorischule Allgäu – Erdkinderplan 2023/24"
        poster={erdkinderplanPoster}
        posterAlt="Schülerinnen und Schüler bewegen gemeinsam den alten Anhänger für ihr Bauwagenprojekt"
        duration="2:48 Minuten"
        caption="Ein Jahr Erdkinderplan: Die Sekundaria B baut gemeinsam einen Bauwagen."
      />
    </div>
  </section>

  <ImageSplit
    image={classImage}
    alt="Kinder arbeiten in einer jahrgangsgemischten Lerngruppe"
    reverse
    position="center 40%"
  >
    <p class="eyebrow">Abschlüsse</p>
    <h2>Ein Abschluss ist ein Wegweiser – nicht der Wert eines Kindes.</h2>
    <p>
      Wir bereiten auf anerkannte Abschlüsse vor, ohne die gesamte Schulzeit dem Prüfungsformat
      unterzuordnen. Gemeinsam mit dem jungen Menschen und der Familie klären wir Ziel, Lernstand
      und nächste Schritte.
    </p>
    <ul class="editorial-list">
      <li>Qualifizierender Abschluss der Mittelschule („Quali“) nach der 9. Jahrgangsstufe</li>
      <li>
        Mittlerer Schulabschluss an der Mittelschule („Mittlere Reife“) nach der 10. Jahrgangsstufe
      </li>
    </ul>
    <p class="small muted">
      Die staatlichen Prüfungen legen unsere Jugendlichen an einer kooperierenden staatlichen
      Mittelschule ab.
    </p>
  </ImageSplit>

  <section class="section section--light">
    <div class="container grid-2 school-rhythm">
      <div>
        <p class="eyebrow">Alltag</p>
        <h2>Rhythmus gibt Sicherheit.</h2>
        <p class="lead">
          Morgenkreise, Freiarbeit, Fachunterricht, Bewegung, Projekte und gemeinsame Verantwortung
          bilden einen verlässlichen Wochenrahmen.
        </p>
        <h3>Schulzeiten</h3>
        <ul class="editorial-list school-times">
          <li><strong>Primaria:</strong> {openingHours.school.primaria}</li>
          <li>
            <strong>Sekundaria &amp; Tertia:</strong>{" "}{openingHours.school.secundariaAndTertia}
          </li>
        </ul>
        <p>
          Klassenrat und Schülerversammlung geben jungen Menschen eine echte Stimme. Konflikte
          werden nicht vermieden oder über Schuld gelöst, sondern angesprochen, geklärt und als
          Lernraum genutzt.
        </p>
        <TextLink href="/kindergarten-schule/ganztag-verpflegung/" label="Ganztag & Verpflegung" />
      </div>
      <div class="image-frame image-frame--landscape school-rhythm__image">
        <img
          src={roomImage.src}
          alt="Vorbereiteter Klassenraum der Montessori-Schule"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <CTASection
    title="Einschulung beginnt mit einem ehrlichen Kennenlernen."
    text="Ihr sollt wissen, was ihr von uns erwarten könnt – und was nicht. Wir möchten nicht möglichst viele, sondern passende Familien aufnehmen."
    primaryHref="/kennenlernen/aufnahme-schule/"
    primaryLabel="Aufnahme Schule"
    secondaryHref="/kennenlernen/haeufige-fragen/"
    secondaryLabel="Häufige Fragen"
  />
</BaseLayout>

<style>
  .stage-card blockquote {
    min-height: 5.8rem;
    margin: 1.5rem 0;
    color: var(--color-ink);
    font-family: var(--display);
    font-size: clamp(1.8rem, 2.35vw, 2.45rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .stage-card > p:last-child {
    margin-bottom: 0;
  }

  .stage-note {
    max-width: 54rem;
    margin: clamp(1.5rem, 3vw, 2.25rem) auto 0;
    text-align: center;
  }

  @media (max-width: 1050px) {
    .stage-card blockquote {
      min-height: 0;
    }
  }

  @media (min-width: 841px) {
    .school-rhythm {
      align-items: stretch;
    }

    .school-rhythm__image {
      aspect-ratio: auto;
    }
  }

  .school-times {
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }

  .erdkinderplan {
    border-block: 1px solid var(--color-line);
  }

  .erdkinderplan__intro {
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .erdkinderplan__intro h2 {
    max-width: 36rem;
    scroll-margin-top: calc(var(--header-height) + 1rem);
  }

  .erdkinderplan__intro p:last-child {
    margin-bottom: 0;
  }
</style>
