---
import { Download } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import CTASection from "@/components/CTASection.astro";
import { getDownloads } from "@/data/content";

const downloads = await getDownloads();
const sectionTitles = ["Schule", "Kindergarten", "Verein"] as const;
const sections = sectionTitles.map((title) => ({
  title,
  files: downloads.filter((download) => download.group === title),
}));
---

<BaseLayout
  title="Downloads"
  description="Infohefte, pädagogische Konzepte, Aufnahmeunterlagen, Monte-ABC und Vereinsunterlagen der Montessori Allgäu als PDF."
>
  <PageIntro
    eyebrow="Downloads"
    title="Unterlagen zum Nachlesen."
    intro="Hier findet ihr pädagogische Konzepte, Aufnahmeunterlagen und Informationen für Familien. Der jeweilige Stand steht direkt beim Dokument – ältere Inhalte werden schrittweise überarbeitet."
  />

  <section class="section">
    <div class="container">
      {
        sections.map((section) => (
          <section
            class="download-section"
            aria-labelledby={`download-${section.title.toLowerCase().replaceAll(" ", "-")}`}
          >
            <p class="eyebrow">Dokumente</p>
            <h2 id={`download-${section.title.toLowerCase().replaceAll(" ", "-")}`}>
              {section.title}
            </h2>
            <div class="download-list">
              {section.files.map((file) => (
                <a class="download-row" href={file.file}>
                  <div>
                    <h3>{file.title}</h3>
                    <p>{file.meta}</p>
                  </div>
                  <Download size={22} aria-hidden="true" />
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <CTASection
    title="Ein Dokument fehlt oder ist unklar?"
    text="Meldet euch beim Schulbüro. Rechtlich verbindlich sind die jeweils aktuell unterzeichneten Verträge und Vereinbarungen."
    primaryHref="/kontakt/"
    primaryLabel="Kontakt"
  />
</BaseLayout>

<style>
  .download-section + .download-section {
    margin-top: clamp(5rem, 10vw, 9rem);
  }

  .download-section > h2 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
  }

  .download-row :global(svg) {
    color: var(--terracotta-text);
  }
</style>
