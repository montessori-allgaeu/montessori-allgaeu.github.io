---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import CTASection from "@/components/CTASection.astro";
import TextLink from "@/components/TextLink.astro";
import { getWebsiteSettings } from "@/data/content";

const { schoolAdmission } = await getWebsiteSettings();
---

<BaseLayout
  title="Aufnahme Schule"
  description="Der Aufnahmeprozess der Montessori-Schule Allgäu: Infoabend, Absichtserklärung, Hospitation, Kennenlernen und gemeinsame Entscheidung."
>
  <PageIntro
    eyebrow="Aufnahme Schule"
    title="Aufnahme ist eine gemeinsame Entscheidung."
    intro="Bei jeder Aufnahme schauen wir auf das einzelne Kind, die Familie und die Klassengemeinschaft. Entscheidend ist, ob das Kind und unsere Montessori-Pädagogik gut zueinander passen."
  >
    <TextLink
      href="/downloads/absichtserklaerung-schule.pdf"
      label="Absichtserklärung herunterladen"
    />
  </PageIntro>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Schuljahr {schoolAdmission.schoolYear}</p>
        <h2>Jetzt anmelden.</h2>
        <div class="notice">
          <p>
            Für die Einschulung im Schuljahr {schoolAdmission.schoolYear} könnt ihr die ausgefüllte Absichtserklärung
            bis zum <time datetime={schoolAdmission.applicationDeadline}
              >{schoolAdmission.applicationDeadlineLabel}</time
            > per E-Mail oder Post an das Schulbüro senden.
          </p>
        </div>
      </div>
      <div>
        <p class="lead">
          Infoabende, Tage der offenen Tür und weitere Möglichkeiten, die Monte persönlich
          kennenzulernen, veröffentlichen wir auf unserer Terminseite.
        </p>
        <div class="button-row">
          <a class="button" href="/downloads/absichtserklaerung-schule.pdf"
            >Absichtserklärung herunterladen</a
          >
          <a class="button button--outline" href="/termine/">Termine ansehen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Der Ablauf</p>
        <h2>Vom ersten Eindruck zur Aufnahme.</h2>
      </div>
      <ol class="steps">
        <li class="step">
          <div>
            <h3>Tag der offenen Tür und Infoabend</h3><p>
              Ihr lernt Montessori-Arbeit, Schulalltag, Abschlusswege, Elternrolle und unseren
              Aufnahmeprozess kennen. Der Infoabend ist verbindlicher Teil des Wegs.
            </p>
          </div>
        </li>
        <li class="step">
          <div>
            <h3>Absichtserklärung</h3><p>
              Innerhalb der veröffentlichten Frist reicht ihr eure Unterlagen im Schulbüro ein.
            </p>
          </div>
        </li>
        <li class="step">
          <div>
            <h3>Sichtung</h3><p>
              Wir prüfen verfügbare Plätze und ob eine Fortsetzung des Aufnahmeprozesses sinnvoll
              erscheint.
            </p>
          </div>
        </li>
        <li class="step">
          <div>
            <h3>Hospitation der Eltern</h3><p>
              Ihr erlebt den Unterricht und sprecht persönlich mit uns über eure Beobachtungen,
              Erwartungen und Fragen.
            </p>
          </div>
        </li>
        <li class="step">
          <div>
            <h3>Kennenlernnachmittag für Kinder</h3><p>
              Auch euer Kind soll uns erleben und sich ein eigenes Bild machen können. Wir
              beobachten, wie es sich im Rahmen bewegt und in Kontakt kommt.
            </p>
          </div>
        </li>
        <li class="step">
          <div>
            <h3>Entscheidung</h3><p>
              Wir entscheiden mit Blick darauf, wie Kind, Familie und unsere Pädagogik
              zusammenpassen, sowie auf Klassengemeinschaft und freie Kapazität. Zum angekündigten
              Termin melden wir uns bei euch.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Quereinstieg</p>
        <h2>Bewusst hin zu Montessori.</h2>
      </div>
      <div>
        <p class="lead">
          Wenn in höheren Klassen Plätze frei werden, können auch Quereinsteiger:innen Teil unserer
          Monte werden. Entscheidend ist, dass Kind, Familie, Klassengemeinschaft und unsere
          Pädagogik gut zusammenpassen.
        </p>
        <p>
          Schwierigkeiten an der bisherigen Schule schließen eine Aufnahme nicht aus. Sie allein
          bedeuten aber noch nicht, dass Montessori der passende Weg ist. Entscheidend ist das Ja zu
          unserer Pädagogik – nicht nur der Wunsch, ein anderes System zu verlassen.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Noch Fragen zur Schule?"
    text="Schaut zuerst in unsere häufigen Fragen. Wenn eure Frage dort nicht beantwortet wird, hilft euch das Schulbüro gerne weiter."
    primaryHref="/kennenlernen/haeufige-fragen/"
    primaryLabel="Häufige Fragen lesen"
    secondaryHref="/kontakt/"
    secondaryLabel="Schulbüro kontaktieren"
  />
</BaseLayout>
