---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import CTASection from "@/components/CTASection.astro";
import TextLink from "@/components/TextLink.astro";
import { getWebsiteSettings } from "@/data/content";

const { costs } = await getWebsiteSettings();
---

<BaseLayout
  title="Kosten & Mitarbeit"
  description="Transparente Übersicht über Schulgeld, Kindergartenbeiträge, Elterneinlage, Vereinsbeitrag und verbindliche Elternarbeitsstunden der Montessori Allgäu."
>
  <PageIntro
    eyebrow="Kosten & Mitarbeit"
    title="Private Bildung, gemeinsam getragen."
    intro="Als freie, gemeinnützige Einrichtung erhalten wir öffentliche Zuschüsse, müssen aber einen wesentlichen Teil selbst tragen. Familien beteiligen sich finanziell und mit verbindlicher Mitarbeit."
  />

  <section class="section">
    <div class="container">
      <div class="cost-section grid-2">
        <div>
          <p class="eyebrow">Schule</p>
          <h2>Monatliches Schulgeld</h2>
          <p>{costs.schoolFees.intro}</p>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Kind in der Familie</th><th>pro Monat</th></tr></thead>
            <tbody>
              {
                costs.schoolFees.rows.map((row) => (
                  <tr>
                    <>
                      <td>{row.label}</td>
                      <td>
                        <strong>{row.amount}</strong>
                      </td>
                    </>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>

      <div class="cost-section grid-2">
        <div>
          <p class="eyebrow">Kindergarten</p>
          <h2>Monatlicher Elternbeitrag</h2>
          <p>{costs.kindergartenFees.intro}</p>
        </div>
        <div class="table-wrap">
          <div class="kindergarten-subsidy">
            <div>
              <p class="eyebrow">Beitragszuschuss Bayern</p>
              <p class="kindergarten-subsidy__amount">−{costs.kindergartenFees.subsidyAmount}</p>
            </div>
            <p>{costs.kindergartenFees.subsidyNote}</p>
          </div>
          <table>
            <thead>
              <tr>
                <th>Buchungszeit</th>
                <th>Grundbeitrag*</th>
                <th>Effektiv mit Zuschuss*</th>
              </tr>
            </thead>
            <tbody>
              {
                costs.kindergartenFees.rows.map((row) => (
                  <tr>
                    <>
                      <td>{row.label}</td>
                      <td>{row.amount}</td>
                      <td>
                        <strong>{row.effectiveAmount}</strong>
                      </td>
                    </>
                  </tr>
                ))
              }
            </tbody>
          </table>
          <p class="small muted">
            * Die angegebenen Grundbeiträge gelten ab 1. September 2026. Bis dahin gelten die
            Beiträge im aktuell veröffentlichten Kindergarten-Aufnahmebogen. Die effektiven Beiträge
            sind unter Berücksichtigung des oben beschriebenen Beitragszuschusses errechnet.
            <a href="https://www.stmas.bayern.de/kinderbetreuung/finanzierung/index.php">
              Aktuelle Informationen zum Beitragszuschuss beim Freistaat Bayern
            </a>
          </p>
        </div>
      </div>

      <div class="cost-section grid-2">
        <div>
          <p class="eyebrow">Gemeinsame Grundlage</p>
          <h2>Elterneinlage</h2>
          <p>{costs.deposit.intro} {costs.deposit.description}</p>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Kind in der Familie</th><th>Einmalige Einlage</th></tr></thead>
            <tbody>
              {
                costs.deposit.rows.map((row) => (
                  <tr>
                    <>
                      <td>{row.label}</td>
                      <td>
                        <strong>{row.amount}</strong>
                      </td>
                    </>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Mitmachschule</p>
        <h2>Zeit ist Teil des Beitrags.</h2>
        <p class="lead">
          {costs.parentWork.intro}
        </p>
      </div>
      <div class="grid-3">
        <article>
          <p class="eyebrow">{costs.parentWork.school.label}</p>
          <h3>{costs.parentWork.school.amount}</h3>
          <p>{costs.parentWork.school.detail}</p>
        </article>
        <article>
          <p class="eyebrow">{costs.parentWork.kindergarten.label}</p>
          <h3>{costs.parentWork.kindergarten.amount}</h3>
          <p>{costs.parentWork.kindergarten.detail}</p>
        </article>
        <article>
          <p class="eyebrow">{costs.parentWork.missedHours.label}</p>
          <h3>{costs.parentWork.missedHours.amount}</h3>
          <p>{costs.parentWork.missedHours.detail}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Verein</p>
        <h2>Mitgliedschaft gehört dazu.</h2>
      </div>
      <div>
        <p class="lead">{costs.membership.intro}</p>
        <ul class="editorial-list">
          {costs.membership.rows.map((row) => <li>{row}</li>)}
        </ul>
        <TextLink
          href="/downloads/beitrittserklaerung-verein.pdf"
          label="Beitrittserklärung herunterladen"
        />
      </div>
    </div>
  </section>

  <CTASection
    title="Kosten sollen vor der Entscheidung klar sein."
    text="Falls noch etwas unklar ist, meldet euch gerne bei uns. Wir helfen euch weiter."
    primaryHref="/kontakt/"
    primaryLabel="Frage an uns stellen"
    secondaryHref="/downloads/"
    secondaryLabel="Verträge & Unterlagen"
  />
</BaseLayout>

<style>
  .cost-section {
    padding: clamp(4rem, 8vw, 8rem) 0;
    border-top: 1px solid var(--line);
  }

  .cost-section:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .cost-section:last-child {
    border-bottom: 1px solid var(--line);
  }

  .kindergarten-subsidy {
    display: grid;
    padding: 1.4rem 1rem;
    background: color-mix(in srgb, var(--ochre) 18%, var(--paper-light));
    gap: 1rem;
    grid-template-columns: minmax(9rem, 0.65fr) minmax(0, 1.35fr);
  }

  .kindergarten-subsidy p {
    margin-bottom: 0;
  }

  .kindergarten-subsidy__amount {
    color: var(--forest);
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
  }

  @media (max-width: 640px) {
    .kindergarten-subsidy {
      grid-template-columns: 1fr;
    }
  }
</style>
