---
import { CalendarDays, Clock, MapPin } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import CTASection from "@/components/CTASection.astro";
import { getEvents } from "@/data/content";

const events = await getEvents();
const dateFromIso = (date: string) => new Date(`${date}T00:00:00Z`);
const day = (date: string) =>
  new Intl.DateTimeFormat("de-DE", { day: "2-digit", timeZone: "UTC" }).format(dateFromIso(date));
const monthAndYear = (date: string) =>
  new Intl.DateTimeFormat("de-DE", { month: "long", year: "numeric", timeZone: "UTC" }).format(
    dateFromIso(date),
  );
const fullDate = (date: string) =>
  new Intl.DateTimeFormat("de-DE", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  }).format(dateFromIso(date));
---

<BaseLayout
  title="Termine"
  description="Aktuelle Termine der Montessori Allgäu: Kennenlernveranstaltungen, Infoabende, Tage der offenen Tür und Termine der Monte-Gemeinschaft."
>
  <PageIntro
    eyebrow="Termine"
    title="Die Monte erleben."
    intro="Hier findet ihr öffentliche Kennenlerntermine und ausgewählte Veranstaltungen der Gemeinschaft. Verbindliche Aufnahmefristen veröffentlichen wir zusätzlich auf den jeweiligen Aufnahmeseiten."
  />

  <section class="section">
    <div class="container">
      {
        events.map((event) => (
          <article class="event">
            <div class="event__date">
              <>
                <span>{day(event.date)}</span>
                <small>{monthAndYear(event.date)}</small>
              </>
            </div>
            <div class="event__content">
              <p class="eyebrow">{event.category}</p>
              <h2>{event.title}</h2>
              <p>{event.description}</p>
              <ul class="event__meta">
                <li>
                  <CalendarDays size={17} aria-hidden="true" />
                  <time datetime={event.date}>{fullDate(event.date)}</time>
                </li>
                <li>
                  <Clock size={17} aria-hidden="true" />
                  {event.time}
                </li>
                <li>
                  <MapPin size={17} aria-hidden="true" />
                  {event.location}
                </li>
              </ul>
            </div>
          </article>
        ))
      }

      <div class="empty-state">
        <p class="eyebrow">Kennenlerntermine</p>
        <h2>Neue Termine folgen.</h2>
        <p class="lead">
          Infoabende, Tag der offenen Tür und Fristen für den nächsten Aufnahmezyklus
          veröffentlichen wir, sobald sie verbindlich feststehen.
        </p>
        <div class="button-row">
          <a class="button button--outline" href="/kennenlernen/aufnahme-kindergarten/"
            >Aufnahme Kindergarten</a
          >
          <a class="button button--outline" href="/kennenlernen/aufnahme-schule/">Aufnahme Schule</a
          >
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Keinen passenden Termin gefunden?"
    text="Für konkrete Aufnahmefragen erreicht ihr den Kindergarten und das Schulbüro direkt per E-Mail oder Telefon."
    primaryHref="/kontakt/"
    primaryLabel="Kontakt"
    secondaryHref="/kennenlernen/"
    secondaryLabel="Kennenlernweg"
  />
</BaseLayout>

<style>
  .event {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6rem);
    padding: clamp(2rem, 5vw, 4rem) 0;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line);
  }

  .event + .event {
    border-top: 0;
  }

  .event__date {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    color: var(--terracotta-text);
  }

  .event__date span {
    font-family: var(--serif);
    font-size: 5rem;
    line-height: 0.85;
  }

  .event__date small {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .event__date small::first-letter {
    text-transform: uppercase;
  }

  .event__content h2 {
    font-size: clamp(2.6rem, 5vw, 4.5rem);
  }

  .event__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .event__meta li {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    color: var(--forest-muted);
    font-size: 0.8rem;
  }

  .event__meta svg {
    color: var(--terracotta-text);
  }

  .empty-state {
    max-width: 55rem;
    margin-top: clamp(5rem, 10vw, 9rem);
  }

  @media (max-width: 620px) {
    .event {
      grid-template-columns: 1fr;
    }
  }
</style>
