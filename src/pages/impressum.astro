---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import { getTeam, getWebsiteSettings } from "@/data/content";

const { contact } = await getWebsiteSettings();
const board = (await getTeam())
  .flatMap((member) =>
    member.assignments
      .filter((assignment) => assignment.group === "Vorstand")
      .map((assignment) => ({ member, assignment })),
  )
  .sort(
    (a, b) =>
      a.assignment.position - b.assignment.position ||
      a.member.name.localeCompare(b.member.name, "de"),
  );
---

<BaseLayout
  title="Impressum"
  description="Impressum und Anbieterkennzeichnung der Montessori Allgäu – Kindergarten und Schule in Trägerschaft des gemeinnützigen Monte e.V."
>
  <PageIntro
    eyebrow="Rechtliches"
    title="Impressum"
    intro="Anbieterkennzeichnung und verantwortliche Stellen für die Website der Montessori Allgäu."
  />

  <section class="section">
    <div class="container container--reading prose">
      <h2>Angaben gemäß § 5 DDG</h2>
      <p>
        Verein zur Förderung der Montessori-Pädagogik im Grenzgebiet Oberallgäu/Westallgäu und
        Bregenzer Wald (Österreich) e.V.<br />
        {contact.address.street}<br />
        {`${contact.address.postalCode} ${contact.address.locality}`}
      </p>

      <h3>Vertretungsberechtigter Vorstand gemäß § 26 BGB</h3>
      <ul>
        {
          board.map(({ member, assignment }) => (
            <li>
              {member.name}
              {assignment.role ? `, ${assignment.role}` : ""}
            </li>
          ))
        }
      </ul>
      <p>
        Der Verein wird gerichtlich und außergerichtlich durch jeweils zwei Vorstandsmitglieder
        gemeinsam vertreten.
      </p>

      <h3>Kontakt</h3>
      <p>
        Telefon: <a href={`tel:${contact.phoneHref}`}>{contact.phone}</a><br />
        E-Mail: <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </p>

      <h3>Registereintrag</h3>
      <p>Vereinsregister beim Amtsgericht Kempten<br />Registernummer: VR 1539</p>

      <h3>Zuständige Aufsichtsbehörden</h3>
      <p>
        Regierung von Schwaben und Landratsamt Oberallgäu, jeweils im Rahmen ihrer gesetzlichen
        Zuständigkeit.
      </p>

      <h2>Verantwortlich für den Inhalt</h2>
      <p>
        Max Sutter<br />
        {contact.address.street}<br />
        {`${contact.address.postalCode} ${contact.address.locality}`}
      </p>

      <h2>Haftung für Inhalte und Links</h2>
      <p>
        Wir erstellen die Inhalte dieser Website mit Sorgfalt. Für Richtigkeit, Vollständigkeit und
        Aktualität können wir dennoch keine Gewähr übernehmen. Verlinkte externe Seiten liegen
        außerhalb unseres Verantwortungsbereichs. Für deren Inhalte sind ausschließlich die
        jeweiligen Betreiber verantwortlich.
      </p>

      <h2>Urheberrecht</h2>
      <p>
        Texte, Fotografien und Gestaltung dieser Website unterliegen dem Urheberrecht. Eine Nutzung
        über die gesetzlich erlaubten Fälle hinaus ist nur mit vorheriger Zustimmung zulässig. Bei
        einzelnen Bildern können Rechte zusätzlich bei den abgebildeten oder fotografierenden
        Personen liegen.
      </p>
    </div>
  </section>
</BaseLayout>
