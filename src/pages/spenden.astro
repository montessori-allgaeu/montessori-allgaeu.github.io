---
import { Building2, HeartHandshake } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import ImageSplit from "@/components/ImageSplit.astro";
import CTASection from "@/components/CTASection.astro";
import { getDonationPage, getWebsiteSettings } from "@/data/content";
import materialWorkImage from "@/assets/images/editorial/donations-material-work.webp";

const [donations, { contact }] = await Promise.all([getDonationPage(), getWebsiteSettings()]);
const companyMailto = `mailto:${contact.email}?subject=${encodeURIComponent(donations.company.emailSubject)}`;
const receiptMailto = `mailto:${contact.email}?subject=${encodeURIComponent(donations.receipt.emailSubject)}`;
---

<BaseLayout title={donations.seo.title} description={donations.seo.description}>
  <PageIntro
    eyebrow={donations.hero.eyebrow}
    title={donations.hero.title}
    intro={donations.hero.intro}
  />

  <ImageSplit image={materialWorkImage} alt={donations.impact.imageAlt} position="center 48%">
    <p class="eyebrow">{donations.impact.eyebrow}</p>
    <h2>{donations.impact.title}</h2>
    {donations.impact.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  </ImageSplit>

  <section class="section section--light">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{donations.projects.eyebrow}</p>
        <h2>{donations.projects.title}</h2>
        <p>{donations.projects.intro}</p>
      </div>
      <div class="editorial-cards donation-projects">
        {
          donations.projects.items.map((project, index) => (
            <article class="editorial-card">
              <p class="eyebrow">{String(index + 1).padStart(2, "0")}</p>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container support-grid">
      <article class="support-option">
        <HeartHandshake size={42} stroke-width={1.4} aria-hidden="true" />
        <p class="eyebrow">{donations.directDonation.eyebrow}</p>
        <h2>{donations.directDonation.title}</h2>
        <p>{donations.directDonation.intro}</p>
        <dl>
          <div><dt>Empfänger</dt><dd>{donations.directDonation.account.recipient}</dd></div>
          <div><dt>Bank</dt><dd>{donations.directDonation.account.bank}</dd></div>
          <div><dt>IBAN</dt><dd>{donations.directDonation.account.iban}</dd></div>
          <div><dt>BIC</dt><dd>{donations.directDonation.account.bic}</dd></div>
          <div>
            <dt>Verwendungszweck</dt><dd>{donations.directDonation.account.purpose}</dd>
          </div>
        </dl>
        <p class="support-note">{donations.directDonation.note}</p>
      </article>

      <article class="support-option support-option--company">
        <Building2 size={42} stroke-width={1.4} aria-hidden="true" />
        <p class="eyebrow">{donations.company.eyebrow}</p>
        <h2>{donations.company.title}</h2>
        <p class="lead">{donations.company.text}</p>
        <p>{donations.company.detail}</p>
        <a class="button button--outline" href={companyMailto}>{donations.company.buttonLabel}</a>
      </article>
    </div>
  </section>

  <section class="section section--light">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">{donations.receipt.eyebrow}</p>
        <h2>{donations.receipt.title}</h2>
      </div>
      <div>
        <p class="lead">{donations.receipt.intro}</p>
        <p>{donations.receipt.instruction}</p>
        <a class="button button--outline" href={receiptMailto}>{donations.receipt.buttonLabel}</a>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow={donations.otherSupport.eyebrow}
    title={donations.otherSupport.title}
    text={donations.otherSupport.text}
    primaryHref="/downloads/beitrittserklaerung-verein.pdf"
    primaryLabel={donations.otherSupport.primaryLabel}
    secondaryHref="/kontakt/"
    secondaryLabel={donations.otherSupport.secondaryLabel}
  />
</BaseLayout>

<style>
  .donation-projects {
    gap: 1px;
    border: 1px solid var(--color-line);
    background: var(--color-line);
    grid-template-columns: repeat(auto-fit, minmax(min(17rem, 100%), 1fr));
  }

  .donation-projects .editorial-card {
    min-height: 18rem;
    border: 0;
    background: var(--color-surface);
  }

  .support-grid {
    display: grid;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .support-option {
    padding: clamp(2rem, 5vw, 4.5rem);
  }

  .support-option + .support-option {
    border-left: 1px solid var(--color-line);
  }

  .support-option > svg {
    margin-bottom: 2rem;
    color: var(--color-link);
  }

  .support-option dl {
    margin: 2rem 0 0;
    border-top: 1px solid var(--color-line-strong);
  }

  .support-option dl div {
    display: grid;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-line);
    gap: 1rem;
    grid-template-columns: minmax(8rem, 0.6fr) minmax(0, 1fr);
  }

  .support-option dt {
    color: var(--color-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .support-option dd {
    margin: 0;
    color: var(--color-ink);
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .support-note {
    margin-top: 1.5rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .support-option--company .button {
    margin-top: 1rem;
  }

  @media (max-width: 800px) {
    .support-grid {
      grid-template-columns: 1fr;
    }

    .support-option + .support-option {
      border-top: 1px solid var(--color-line);
      border-left: 0;
    }
  }

  @media (max-width: 520px) {
    .support-option dl div {
      grid-template-columns: 1fr;
    }
  }
</style>
