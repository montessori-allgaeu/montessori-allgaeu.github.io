---
import { Mail, MapPin, Phone } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";
import OpeningHoursList from "@/components/OpeningHoursList.astro";
import { getWebsiteSettings } from "@/data/content";

const { contact, openingHours } = await getWebsiteSettings();
const mapQuery = encodeURIComponent(
  `${contact.address.street}, ${contact.address.postalCode} ${contact.address.locality}`,
);
---

<BaseLayout
  title="Kontakt"
  description="Kontakt zu Montessori-Schule und Kindergarten Allgäu in Oberstaufen/Kalzhofen: E-Mail, Telefon, Anschrift, Büro- und Öffnungszeiten."
>
  <PageIntro
    eyebrow="Kontakt"
    title="Wir freuen uns, von euch zu hören."
    intro="Für Aufnahme, Alltag und Schule hilft das Schulbüro weiter. Fragen zum Kindergarten gehen direkt an die Kindergartenleitung."
  />

  <section class="section">
    <div class="container contact-grid">
      <article class="contact-panel">
        <p class="eyebrow">Schule</p>
        <h2>Schulbüro</h2>
        <address>{contact.address.street}<br />{contact.address.city}</address>
        <p>
          <a href={`mailto:${contact.email}`}
            ><Mail size={18} aria-hidden="true" />{contact.email}</a
          >
        </p>
        <p>
          <a href={`tel:${contact.phoneHref}`}
            ><Phone size={18} aria-hidden="true" />{contact.phone}</a
          >
        </p>
        <h3>Öffnungszeiten</h3>
        <ul class="editorial-list">
          {openingHours.schoolOffice.map((hours) => <li>{hours}</li>)}
        </ul>
      </article>
      <article class="contact-panel">
        <p class="eyebrow">Kindergarten</p>
        <h2>Kindergartenleitung</h2>
        <address>{contact.address.street}<br />{contact.address.city}</address>
        <p>
          <a href={`mailto:${contact.kindergartenEmail}`}
            ><Mail size={18} aria-hidden="true" />{contact.kindergartenEmail}</a
          >
        </p>
        <p>
          <a href={`tel:${contact.kindergartenPhoneHref}`}
            ><Phone size={18} aria-hidden="true" />{contact.kindergartenPhone}</a
          >
        </p>
        <h3>Öffnungszeiten</h3>
        <OpeningHoursList entries={openingHours.kindergarten} />
      </article>
    </div>
  </section>

  <section class="section section--light">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Anfahrt</p>
        <h2>In Kalzhofen bei Oberstaufen.</h2>
        <p class="lead">
          Kindergarten und Schule liegen gemeinsam in der {contact.address.street}.
        </p>
        <a
          class="button button--outline"
          href={`https://www.openstreetmap.org/search?query=${mapQuery}`}
          target="_blank"
          rel="noreferrer"><MapPin size={18} aria-hidden="true" />Route auf OpenStreetMap öffnen</a
        >
      </div>
      <div>
        <p class="eyebrow">Datenschutzfreundlich</p>
        <h3>Keine eingebettete Karte, kein allgemeines Kontaktformular.</h3>
        <p>
          Die Karte öffnet sich erst, wenn ihr den externen Link anklickt. Beim Kontakt per E-Mail
          werden die von euch übermittelten Angaben zur Bearbeitung eurer Anfrage verwendet. Für
          Anliegen ohne Namensangabe an den Vorstand gibt es auf der Seite
          <a href="/gemeinschaft/traeger-verein/">Träger &amp; Verein</a> einen gesonderten Weg.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-panel p a {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }
</style>
