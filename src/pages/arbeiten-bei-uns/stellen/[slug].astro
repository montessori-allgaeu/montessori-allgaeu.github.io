---
import { ArrowLeft, Check } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTASection from "@/components/CTASection.astro";
import { getJobs, getWebsiteSettings, type Job } from "@/data/content";

export async function getStaticPaths() {
  const jobs = await getJobs();
  return jobs.map((job) => ({ params: { slug: job.slug }, props: { job } }));
}

interface Props {
  job: Job;
}

const { job } = Astro.props;
const { contact } = await getWebsiteSettings();
const mailSubject = encodeURIComponent(`Bewerbung: ${job.title}`);
---

<BaseLayout title={job.title} description={`${job.title} bei Montessori Allgäu: ${job.intro}`}>
  <section class="job-hero">
    <div class="container">
      <a class="text-link job-back" href="/arbeiten-bei-uns/stellen/"
        ><ArrowLeft size={16} aria-hidden="true" />Alle Stellen</a
      >
      <p class="eyebrow">{job.areaLabel}</p>
      <h1>{job.title}</h1>
      <div class="job-hero__meta">
        <p class="lead">{job.intro}</p>
        <span>{job.scheduleLabel}</span>
      </div>
    </div>
  </section>

  <section class="section job-about">
    <div class="container grid-2">
      <div><p class="eyebrow">Über uns</p><h2>Ein Ort für eigenständiges Lernen.</h2></div>
      <div class="job-about__copy">
        {job.about.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2 job-content">
      <div>
        <p class="eyebrow">Deine Aufgabe</p>
        <h2>Was du bei uns gestaltest.</h2>
        <ul class="job-checks">
          {
            job.responsibilities.map((item) => (
              <li>
                <Check size={19} aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="eyebrow">Dein Profil</p>
        <h2>Was du mitbringst.</h2>
        <ul class="job-checks">
          {
            job.profile.map((item) => (
              <li>
                <Check size={19} aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Wir bieten</p><h2>Was dich bei uns erwartet.</h2>
      </div>
      <div>
        <ul class="editorial-list">
          {job.benefits.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Interesse?"
    title={job.closingTitle}
    text={job.closingText}
    primaryHref={`mailto:${contact.careersEmail}?subject=${mailSubject}`}
    primaryLabel="Per E-Mail bewerben"
    secondaryHref={`mailto:${contact.careersEmail}?subject=${encodeURIComponent(`Kennenlernen: ${job.title}`)}`}
    secondaryLabel="Erst kennenlernen"
  />
</BaseLayout>

<style>
  .job-hero {
    padding: clamp(4rem, 8vw, 8rem) 0 clamp(4rem, 7vw, 7rem);
    border-bottom: 1px solid var(--line);
  }

  .job-back {
    margin-bottom: clamp(4rem, 8vw, 7rem);
  }

  .job-hero h1 {
    max-width: 64rem;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .job-hero__meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 3rem;
    align-items: end;
  }

  .job-hero__meta span {
    color: var(--forest-muted);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .job-content h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .job-about__copy p:first-child {
    margin-top: 0;
  }

  .job-checks {
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .job-checks li {
    display: grid;
    grid-template-columns: 1.5rem minmax(0, 1fr);
    gap: 0.75rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--forest-soft);
  }

  .job-checks svg {
    margin-top: 0.3rem;
    color: var(--terracotta-text);
  }

  @media (max-width: 700px) {
    .job-hero__meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
