---
import { Image } from "astro:assets";
import { ArrowRight } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ImageSplit from "@/components/ImageSplit.astro";
import TextLink from "@/components/TextLink.astro";
import { getDonationPage } from "@/data/content";
import homeHeroImage from "@/assets/images/editorial/home-hero-focus.webp";
import continuumImage from "@/assets/images/editorial/continuum.webp";
import freedomImage from "@/assets/images/editorial/freedom.webp";
import homeCommunityImage from "@/assets/images/editorial/home-community-event.webp";
import careersPresentationImage from "@/assets/images/editorial/careers-presentation.webp";

const donations = await getDonationPage();
---

<BaseLayout
  title="Montessori-Kindergarten & Schule in Oberstaufen"
  description="Montessori-Kindergarten und Schule in Oberstaufen: Kinder vom Kindergarten bis zur 10. Klasse warm, klar und an ihrem eigenen inneren Kompass orientiert begleiten."
>
  <section class="home-hero">
    <div class="home-hero__content">
      <div class="home-hero__inner">
        <p class="eyebrow">Montessori-Kindergarten und Schule in Oberstaufen</p>
        <h1>Dem eigenen inneren Kompass vertrauen.</h1>
        <p class="lead">
          Vom Kindergarten bis zur 10. Klasse begleiten wir Kinder auf ihrem eigenen Weg – mit
          Wärme, Klarheit und Vertrauen.
        </p>
        <div class="button-row">
          <a class="button" href="/kennenlernen/">Monte kennenlernen</a>
          <a class="text-link" href="/kindergarten-schule/">
            Kindergarten & Schule entdecken <ArrowRight size={16} aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
    <div class="home-hero__media">
      <Image
        src={homeHeroImage}
        alt="Drei Kinder arbeiten mit Stellenwertkarten und goldenem Montessori-Perlenmaterial; im Hintergrund liegt eine Tausenderkette"
        widths={[640, 960, 1280]}
        sizes="(max-width: 840px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="section section--light home-beliefs">
    <div class="container">
      <div class="section-heading home-belief">
        <p class="eyebrow">Was uns leitet</p>
        <h2>Was Kinder bei uns lernen, beginnt bei ihnen selbst.</h2>
      </div>
      <div class="numbered-points">
        <article class="numbered-point">
          <span class="numbered-point__number">01</span>
          <h3>Sich selbst vertrauen</h3>
          <p>
            Wir stärken das Selbstvertrauen und die innere Sicherheit – die Grundlage für
            neugieriges, mutiges und zugewandtes Handeln.
          </p>
        </article>
        <article class="numbered-point">
          <span class="numbered-point__number">02</span>
          <h3>Selbstbestimmt lernen</h3>
          <p>
            Kinder folgen ihren Interessen, entdecken Zusammenhänge und erleben, wie Lernen von
            innen heraus entsteht.
          </p>
        </article>
        <article class="numbered-point">
          <span class="numbered-point__number">03</span>
          <h3>Freiheit gut nutzen</h3>
          <p>
            Freiheit bedeutet Wahlmöglichkeiten – und die Verantwortung, gut mit sich selbst,
            anderen und der Welt umzugehen.
          </p>
        </article>
      </div>
    </div>
  </section>

  <ImageSplit
    image={continuumImage}
    alt="Kinder lernen gemeinsam mit Montessori-Material"
    compact
    position="center 38%"
  >
    <p class="eyebrow">Ein gemeinsamer Bildungsweg</p>
    <h2>Eine Monte.<br />Ein gemeinsamer Weg.</h2>
    <hr class="rule" />
    <div class="path-line" aria-label="Kindergarten bis zur 10. Klasse">
      <span>Kindergarten</span><span class="path-line__line"></span><span>Schule</span><span
        class="path-line__line"></span><span>10. Klasse</span>
    </div>
    <p>
      Von Anfang an wachsen Kinder in einer Umgebung auf, die ihnen Kontinuität, Orientierung und
      echte Beziehungen schenkt – bis zum Abschluss und darüber hinaus.
    </p>
    <TextLink href="/kindergarten-schule/" label="Kindergarten & Schule" />
  </ImageSplit>

  <ImageSplit
    image={freedomImage}
    alt="Ein Kind lernt gemeinsam mit einer Pädagogin"
    reverse
    light
    compact
    position="center 36%"
  >
    <p class="eyebrow">Freiheit in klaren Grenzen</p>
    <h2>Freiheit ist nicht Beliebigkeit.</h2>
    <hr class="rule" />
    <p>
      In einer vorbereiteten Umgebung mit klaren Regeln erfahren Kinder Verlässlichkeit und Halt. So
      können sie sich frei entfalten, Fehler machen, Verantwortung übernehmen – und über sich
      hinauswachsen.
    </p>
    <TextLink href="/montessori/" label="Mehr über Montessori" />
  </ImageSplit>

  <section class="section home-fit">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Eine bewusste Entscheidung</p>
        <h2>Nicht nur weg von Regelschule.<br />Hin zu Montessori.</h2>
        <hr class="rule fit-rule" />
      </div>
      <div class="editorial-cards">
        <article class="editorial-card">
          <p class="eyebrow">Weniger Druck. Mehr Kind.</p>
          <h3>Vertrauen statt schieben.</h3>
          <p>
            Ihr Kind soll mit Freude lernen und neugierig bleiben? Wir nehmen Zeit für Entwicklung –
            statt für Stofffülle, Notendruck und einen vorgegebenen Takt.
          </p>
          <TextLink href="/kennenlernen/haeufige-fragen/" label="Für wen ist Montessori?" />
        </article>
        <article class="editorial-card">
          <p class="eyebrow">Echte Beziehungen</p>
          <h3>Verbindung vor Bewertung.</h3>
          <p>
            Kinder brauchen Erwachsene, die sie wirklich sehen und begleiten. Bei uns entsteht
            Beziehung nicht als Zugabe, sondern als Grundlage für Entwicklung.
          </p>
          <TextLink href="/gemeinschaft/team/" label="Unser Miteinander" />
        </article>
        <article class="editorial-card">
          <p class="eyebrow">Werte, die tragen</p>
          <h3>Eine Gemeinschaft, die mitmacht.</h3>
          <p>
            Du wünschst dir einen Ort, an dem das Kind im Mittelpunkt steht und Gemeinschaft
            wirklich gelebt wird? Respekt, Ehrlichkeit und aktive Mitarbeit prägen unseren Alltag.
          </p>
          <TextLink href="/gemeinschaft/" label="Unsere Gemeinschaft" />
        </article>
      </div>
    </div>
  </section>

  <ImageSplit
    image={homeCommunityImage}
    alt="Kinder und Erwachsene erleben gemeinsam eine Einschulungsfeier"
    light
    compact
    position="center 45%"
  >
    <p class="eyebrow">Gemeinschaft</p>
    <h2>Die Monte wird von Menschen getragen.</h2>
    <p>
      Eltern, Pädagog:innen und Kinder gestalten Schule und Gemeinschaft gemeinsam. Offen, ehrlich
      und auf Augenhöhe. Unsere Prinzipien helfen allen Menschen mit Verantwortung, gute
      Entscheidungen zu treffen.
    </p>
  </ImageSplit>

  <ImageSplit
    image={careersPresentationImage}
    alt="Eine Pädagogin begleitet eine kosmische Erzählung mit Vulkanmodell, während Kinder aufmerksam zuschauen"
    reverse
    compact
    position="42% 50%"
  >
    <p class="eyebrow">Arbeiten bei uns</p>
    <h2>Pädagogik, die du wirklich vertreten kannst.</h2>
    <hr class="rule" />
    <p>
      Du willst Kinder auf ihrem Weg begleiten und deine Stärken einbringen? Bei uns findest du
      Gestaltungsfreiheit, ein lernendes Team und eine Kultur mit viel Wärme und Klarheit.
    </p>
    <TextLink href="/arbeiten-bei-uns/" label="Arbeiten bei uns" />
  </ImageSplit>

  <section class="section section--light section--compact">
    <div class="container grid-2 home-support">
      <div>
        <p class="eyebrow">{donations.homepage.eyebrow}</p>
        <h2>{donations.homepage.title}</h2>
      </div>
      <div>
        <p class="lead">{donations.homepage.text}</p>
        <TextLink href="/spenden/" label={donations.homepage.label} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    height: clamp(700px, calc(100svh - var(--header-height)), 780px);
  }

  .home-hero__content {
    display: flex;
    align-items: center;
    padding: clamp(4rem, 6vw, 6rem) clamp(2rem, 4vw, 4.5rem);
  }

  .home-hero__inner {
    width: min(100%, 42rem);
    margin-left: auto;
  }

  .home-hero h1 {
    font-size: clamp(3.7rem, 5vw, 5rem);
  }

  .home-hero__media {
    min-height: 0;
    overflow: hidden;
    background: var(--color-line);
  }

  .home-hero__media :global(picture),
  .home-hero__media :global(img) {
    width: 100%;
    height: 100%;
  }

  .home-hero__media :global(img) {
    object-fit: cover;
    object-position: 56% 50%;
  }

  .home-belief {
    max-width: 52rem;
  }

  .home-belief h2 {
    font-size: clamp(2.5rem, 4.3vw, 3.9rem);
  }

  .home-beliefs {
    padding-block: clamp(4rem, 5vw, 5rem);
  }

  .home-beliefs .numbered-points {
    margin-top: clamp(2.5rem, 3vw, 3rem);
  }

  .home-fit {
    padding: clamp(4rem, 5vw, 4.5rem) 0 0;
  }

  .home-fit .section-heading {
    margin-bottom: clamp(2.25rem, 3vw, 3rem);
  }

  .home-fit .section-heading h2 {
    font-size: clamp(2.35rem, 4.3vw, 3.9rem);
  }

  .home-fit .editorial-card {
    min-height: 0;
    padding: clamp(2rem, 3vw, 2.75rem);
  }

  .home-support {
    align-items: center;
  }

  .fit-rule {
    margin-inline: auto;
  }

  @media (max-width: 840px) {
    .home-hero {
      grid-template-columns: 1fr;
      height: auto;
    }

    .home-hero__content {
      padding: 5rem 1.5rem;
    }

    .home-hero__media {
      min-height: min(88vw, 620px);
    }
  }

  @media (max-width: 520px) {
    .home-hero h1 {
      font-size: clamp(3.25rem, 16vw, 4.8rem);
    }
  }
</style>
