---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getWebsiteSettings } from "@/data/content";
import { site } from "@/data/site";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  canonicalPath?: string;
}

const {
  title,
  description,
  image = "/social-card-montessori-allgaeu.jpg",
  imageAlt = "Ein Schüler arbeitet konzentriert mit Montessori-Material; daneben steht Montessori Allgäu – Kindergarten & Schule in Oberstaufen.",
  noindex = false,
  canonicalPath,
} = Astro.props;
const { contact } = await getWebsiteSettings();

const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const canonical = new URL(canonicalPath ?? Astro.url.pathname, site.url);
const socialImage = new URL(image, site.url);
const logo = new URL("/favicon.png", site.url);
const organizationId = new URL("/#organization", site.url);
const websiteId = new URL("/#website", site.url);
const webpageId = new URL(`${canonical.pathname}#webpage`, site.url);
const imageId = new URL(`${socialImage.pathname}#primaryimage`, site.url);
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["School", "Preschool"],
      "@id": organizationId,
      name: "Montessori Allgäu – Kindergarten & Schule",
      alternateName: site.name,
      description:
        "Montessori-Kindergarten und Schule in Oberstaufen vom Kindergarten bis zur 10. Klasse.",
      url: site.url,
      logo: {
        "@type": "ImageObject",
        url: logo,
        width: 512,
        height: 512,
      },
      image: { "@id": imageId },
      email: contact.email,
      telephone: contact.phoneHref,
      address: {
        "@type": "PostalAddress",
        streetAddress: contact.address.street,
        postalCode: contact.address.postalCode,
        addressLocality: contact.address.locality,
        addressCountry: "DE",
      },
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: site.url,
      name: site.name,
      description: "Montessori-Kindergarten und Schule in Oberstaufen",
      inLanguage: "de-DE",
      publisher: { "@id": organizationId },
    },
    {
      "@type": "ImageObject",
      "@id": imageId,
      url: socialImage,
      contentUrl: socialImage,
      width: 1200,
      height: 630,
      caption: imageAlt,
    },
    {
      "@type": "WebPage",
      "@id": webpageId,
      url: canonical,
      name: pageTitle,
      description,
      inLanguage: "de-DE",
      isPartOf: { "@id": websiteId },
      about: { "@id": organizationId },
      primaryImageOfPage: { "@id": imageId },
    },
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f5f1ec" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de-DE" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
